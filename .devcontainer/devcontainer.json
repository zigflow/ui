{
  "image": "ghcr.io/mrsimonemms/devcontainers/full",
  "name": "devcontainer",
  "features": {
    "ghcr.io/dhoeric/features/trivy:1": {},
    "ghcr.io/devcontainers-extra/features/go-task:1": {},
    "ghcr.io/rio/features/skaffold:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "svelte.svelte-vscode"
      ],
      "settings": {}
    }
  },
  "postCreateCommand": {
    "playwright": "npx --yes playwright install --with-deps"
  },
  "containerEnv": {
    "PLAYWRIGHT_HTML_HOST": "0.0.0.0",
    "PUBLIC_WORKFLOWS_DIR": "/workspaces/studio/workflows",
    "HOST": "0.0.0.0"
  },
  "forwardPorts": [
    5173
  ]
}
